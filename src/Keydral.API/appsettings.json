{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/keydral-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithEnvironmentName"],
    "Properties": {
      "Application": "Keydral.API",
      "Environment": "Development"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Url": "http://localhost:8080",
    "Realm": "keydral",
    "ClientId": "keydral-api",
    "ClientSecret": ""
  },
  "Database": {
    "Provider": "postgres",
    "ConnectionString": "Server=localhost;Port=5432;Database=keydral;User Id=keydral;Password=keydral_dev_password;"
  },
  "Encryption": {
    "Provider": "file",
    "Algorithm": "AES-256-GCM",
    "MasterKeyFilePath": "./master-key.txt"
  },
  "Api": {
    "Version": "1.0.0",
    "Title": "Keydral Secrets API",
    "Description": "Local-first secrets and key management service"
  },
  "AuditLogging": {
    "Enabled": true,
    "LogRequestBody": false,
    "LogResponseBody": false,
    "IgnorePaths": ["/health", "/swagger"],
    "SensitiveDataPatterns": [
      "password",
      "secret",
      "token",
      "key",
      "credential"
    ]
  },
  "RateLimiting": {
    "Enabled": true,
    "WhitelistedIPs": [],
    "PerIp": {
      "PermitLimit": 1000,
      "WindowSeconds": 60
    },
    "SecretsGet": {
      "PermitLimit": 100,
      "WindowSeconds": 60
    },
    "SecretsPost": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "AuditLogsGet": {
      "PermitLimit": 50,
      "WindowSeconds": 60
    }
  }
}
