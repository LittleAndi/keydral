    <!-- OAuth 2.0 device flow -->
    <PackageReference Include="IdentityModel" Version="7.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Keydral.Core\Keydral.Core.csproj" />
  </ItemGroup>

</Project>
